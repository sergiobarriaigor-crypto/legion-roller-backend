// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

// Fase 2: modelo mínimo para autenticación real.
// Los campos de la especificación (stats, tecnicas, reconocimientos, etc.)
// se agregan en las fases correspondientes (Perfil, Impulsa, etc.).
model Miembro {
  id           Int      @id @default(autoincrement())
  nombre       String
  telefono     String   @unique
  passwordHash String
  ciudad       String?
  rol          String   @default("usuario") // "usuario" | "admin"
  createdAt    DateTime @default(now())

  // Fase 7: técnicas dominadas (autoevaluación, sección 9 del PDF)
  tecnicaT        Boolean @default(false)
  tecnicaSoul     Boolean @default(false)
  tecnicaMaggi    Boolean @default(false)
  tecnicaParallel Boolean @default(false)

  // Fase 7: estado tipo "story" visible en el mapa (vigencia HORAS_ESTADO = 8h)
  estadoTexto String?
  estadoSetAt DateTime?

  ubicacionActiva          UbicacionActiva?
  recorridos               Recorrido[]
  rsvps                    RsvpRespuesta[]
  posts                    Post[]
  reaccionesPost           ReaccionPost[]
  comentariosPost          ComentarioPost[]
  emprendedor              Emprendedor?
  reaccionesEmprendedor    ReaccionEmprendedor[]
  resenasEmprendedor       ResenaEmprendedor[]
  reconocimientosEnviados  ReconocimientoRecibido[] @relation("reconocimientosEnviados")
  reconocimientosRecibidos ReconocimientoRecibido[] @relation("reconocimientosRecibidos")
  mensajesChat             MensajeChat[]
  lecturasChat             LecturaChat[]
  emergencias              Emergencia[]
}

// Solicitud de registro pendiente de aprobación de un Admin (sección 3 y 13 del PDF)
model SolicitudRegistro {
  id           Int      @id @default(autoincrement())
  nombre       String
  telefono     String   @unique
  ciudad       String?
  passwordHash String
  estado       String   @default("pendiente") // "pendiente" | "aceptada" | "rechazada"
  createdAt    DateTime @default(now())
}

// Fase 3: "Estoy patinando ahora" — una ubicación activa por miembro (sección 5 del PDF).
// La vigencia (HORAS_VIGENCIA_PATINANDO = 4h) se calcula en el backend comparando actualizadoEn,
// no se guarda una fecha de expiración aparte.
model UbicacionActiva {
  id            Int      @id @default(autoincrement())
  miembroId     Int      @unique
  miembro       Miembro  @relation(fields: [miembroId], references: [id])
  lat           Float
  lon           Float
  actualizadoEn DateTime @updatedAt
}

// Fase 3: historial de recorridos grabados (sección 5 y 11 del PDF).
// "puntos" guarda el arreglo [{lat, lon, timestamp}] como JSON en texto (SQLite no tiene tipo arreglo).
model Recorrido {
  id          Int      @id @default(autoincrement())
  miembroId   Int
  miembro     Miembro  @relation(fields: [miembroId], references: [id])
  tipo        String   @default("libre") // "ruta" | "libre"
  distanciaKm Float
  duracionSeg Int
  puntos      String
  createdAt   DateTime @default(now())
}

// Fase 4: feed de publicaciones oficiales de Comunidad (sección 6 del PDF).
// tipo: "comunicado" | "rodada" | "evento" | "resumen" | "alerta" | "estado_rutas" | "anuncio" | "consejo"
model Publicacion {
  id             Int      @id @default(autoincrement())
  tipo           String
  titulo         String
  texto          String
  fecha          String? // "YYYY-MM-DD", solo rodadas/eventos
  hora           String? // "HH:MM"
  puntoEncuentro String?
  rsvp           Boolean  @default(false)
  duracionHoras  Int? // vencimiento; null = no vence
  activaEnMapa   Boolean  @default(false)
  fotos          String? // JSON array de URLs (Fase 10: subida real vía /uploads)
  createdAt      DateTime @default(now())

  rsvps RsvpRespuesta[]
}

// Una respuesta de RSVP por miembro y publicación ("yes" | "maybe" | "no")
model RsvpRespuesta {
  id            Int         @id @default(autoincrement())
  publicacionId Int
  publicacion   Publicacion @relation(fields: [publicacionId], references: [id])
  miembroId     Int
  miembro       Miembro     @relation(fields: [miembroId], references: [id])
  estado        String // "yes" | "maybe" | "no"
  createdAt     DateTime    @default(now())
  actualizadoEn DateTime    @updatedAt

  @@unique([publicacionId, miembroId])
}

// Fase 5: feed social "Post" (sección 7 del PDF) — experiencias personales, distinto de Comunidad.
// Vigencia fija de 7 días (DIAS_VIGENCIA_POST), calculada en el backend igual que Publicacion.
// La subida real de fotos/video con editor de recorte queda para la Fase 10; por ahora "fotoUrl"
// es un link opcional a una imagen.
model Post {
  id        Int      @id @default(autoincrement())
  autorId   Int
  autor     Miembro  @relation(fields: [autorId], references: [id])
  titulo    String
  resena    String
  ubicacion String?
  fotoUrl   String?
  createdAt DateTime @default(now())

  reacciones  ReaccionPost[]
  comentarios ComentarioPost[]
}

model ReaccionPost {
  id        Int      @id @default(autoincrement())
  postId    Int
  post      Post     @relation(fields: [postId], references: [id])
  miembroId Int
  miembro   Miembro  @relation(fields: [miembroId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, miembroId])
}

model ComentarioPost {
  id        Int      @id @default(autoincrement())
  postId    Int
  post      Post     @relation(fields: [postId], references: [id])
  autorId   Int
  autor     Miembro  @relation(fields: [autorId], references: [id])
  texto     String
  createdAt DateTime @default(now())
}

// Fase 6: directorio de emprendedores "Impulsa" (sección 8 del PDF).
// Una ficha por miembro; requiere aprobación de un Admin antes de salir en el directorio público.
model Emprendedor {
  id            Int      @id @default(autoincrement())
  miembroId     Int      @unique
  miembro       Miembro  @relation(fields: [miembroId], references: [id])
  nombreNegocio String
  rubro         String
  descripcion   String
  contacto      String
  ubicacion     String?
  instagram     String?
  facebook      String?
  tiktok        String?
  fotos         String? // JSON array de URLs (Fase 10: subida real vía /uploads)
  aprobado      Boolean  @default(false)
  solicitadoAt  DateTime @default(now())

  reacciones ReaccionEmprendedor[]
  resenas    ResenaEmprendedor[]
  anuncios   AnuncioEmprendedor[]
}

model ReaccionEmprendedor {
  id            Int         @id @default(autoincrement())
  emprendedorId Int
  emprendedor   Emprendedor @relation(fields: [emprendedorId], references: [id])
  miembroId     Int
  miembro       Miembro     @relation(fields: [miembroId], references: [id])
  createdAt     DateTime    @default(now())

  @@unique([emprendedorId, miembroId])
}

model ResenaEmprendedor {
  id            Int         @id @default(autoincrement())
  emprendedorId Int
  emprendedor   Emprendedor @relation(fields: [emprendedorId], references: [id])
  autorId       Int
  autor         Miembro     @relation(fields: [autorId], references: [id])
  texto         String
  createdAt     DateTime    @default(now())
}

model AnuncioEmprendedor {
  id            Int         @id @default(autoincrement())
  emprendedorId Int
  emprendedor   Emprendedor @relation(fields: [emprendedorId], references: [id])
  texto         String
  createdAt     DateTime    @default(now())
}

// Fase 7: reconocimientos entre miembros (sección 9 del PDF). Vigencia de 15 días
// (DIAS_VIGENCIA_RECO), calculada en el backend comparando createdAt.
model ReconocimientoRecibido {
  id        Int      @id @default(autoincrement())
  deId      Int
  de        Miembro  @relation("reconocimientosEnviados", fields: [deId], references: [id])
  paraId    Int
  para      Miembro  @relation("reconocimientosRecibidos", fields: [paraId], references: [id])
  texto     String
  leida     Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Fase 8: chat grupal e individual (sección 9 y 11 del PDF).
// "sala" = "grupal" (chat único general) o "dm-{idMenor}-{idMayor}" para chats 1 a 1.
// Vigencia de 7 días (DIAS_VIGENCIA_CHAT), calculada en el backend comparando createdAt.
model MensajeChat {
  id             Int      @id @default(autoincrement())
  sala           String
  autorId        Int
  autor          Miembro  @relation(fields: [autorId], references: [id])
  texto          String
  referenciaTipo String? // "post" | "emprendedor"
  referenciaId   Int?
  createdAt      DateTime @default(now())

  @@index([sala])
}

// Marca hasta qué momento leyó cada miembro cada sala (para contar mensajes no leídos).
model LecturaChat {
  id         Int      @id @default(autoincrement())
  miembroId  Int
  miembro    Miembro  @relation(fields: [miembroId], references: [id])
  sala       String
  leidoHasta DateTime

  @@unique([miembroId, sala])
}

// Fase 9: SOS / Emergencia (sección 5 del PDF). Solo una emergencia activa por miembro a la vez;
// se conserva el historial (activa=false) en vez de borrar el registro.
model Emergencia {
  id                 Int       @id @default(autoincrement())
  miembroId          Int
  miembro            Miembro   @relation(fields: [miembroId], references: [id])
  motivo             String // "caida" | "salud" | "seguridad" | "otro"
  requiereAmbulancia Boolean   @default(false)
  activa             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  resueltaAt         DateTime?
}
