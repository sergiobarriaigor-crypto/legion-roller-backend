// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

// Fase 2: modelo mínimo para autenticación real.
// Los campos de la especificación (stats, tecnicas, reconocimientos, etc.)
// se agregan en las fases correspondientes (Perfil, Impulsa, etc.).
model Miembro {
  id           Int      @id @default(autoincrement())
  nombre       String
  telefono     String   @unique
  passwordHash String
  ciudad       String?
  rol          String   @default("usuario") // "usuario" | "admin"
  createdAt    DateTime @default(now())

  // Fase 7: técnicas dominadas (autoevaluación, sección 9 del PDF)
  tecnicaT        Boolean @default(false)
  tecnicaSoul     Boolean @default(false)
  tecnicaMaggi    Boolean @default(false)
  tecnicaParallel Boolean @default(false)

  // Fase 7: estado tipo "story" visible en el mapa (vigencia HORAS_ESTADO = 8h)
  estadoTexto String?
  estadoSetAt DateTime?

  // Ajuste post-Fase 11: foto de perfil circular, mostrada en el mapa mientras comparte ubicación
  fotoUrl String?

  ubicacionActiva          UbicacionActiva?
  recorridos               Recorrido[]
  rsvps                    RsvpRespuesta[]
  posts                    Post[]
  reaccionesPost           ReaccionPost[]
  comentariosPost          ComentarioPost[]
  emprendedor              Emprendedor?
  reaccionesEmprendedor    ReaccionEmprendedor[]
  resenasEmprendedor       ResenaEmprendedor[]
  reconocimientosEnviados  ReconocimientoRecibido[] @relation("reconocimientosEnviados")
  reconocimientosRecibidos ReconocimientoRecibido[] @relation("reconocimientosRecibidos")
  mensajesChat             MensajeChat[]
  lecturasChat             LecturaChat[]
  emergencias              Emergencia[]
  historias                Historia[]                @relation("HistoriaAutor")
  vistasHistoria           VistaHistoria[]
  reaccionesHistoria       ReaccionHistoria[]
  mencionesHistoria        MencionHistoria[]
  comentariosHistoria      ComentarioHistoria[]
}

// Solicitud de registro pendiente de aprobación de un Admin (sección 3 y 13 del PDF)
model SolicitudRegistro {
  id           Int      @id @default(autoincrement())
  nombre       String
  telefono     String   @unique
  ciudad       String?
  passwordHash String
  estado       String   @default("pendiente") // "pendiente" | "aceptada" | "rechazada"
  createdAt    DateTime @default(now())
}

// Fase 3: "Estoy patinando ahora" — una ubicación activa por miembro (sección 5 del PDF).
// La vigencia (HORAS_VIGENCIA_PATINANDO = 4h) se calcula en el backend comparando actualizadoEn,
// no se guarda una fecha de expiración aparte.
model UbicacionActiva {
  id            Int      @id @default(autoincrement())
  miembroId     Int      @unique
  miembro       Miembro  @relation(fields: [miembroId], references: [id])
  lat           Float
  lon           Float
  // Ajuste post-Fase 11: "patinando" (solo comparte ubicación) o "ruta" (además graba
  // el recorrido); usado para filtrar el panel de "Patinadores activos".
  modo          String   @default("patinando")
  // Se fija solo al crear (no cambia con cada actualización de posición), para poder
  // mostrar "hace X min" desde que activó el modo, a diferencia de actualizadoEn.
  iniciadoEn    DateTime @default(now())
  actualizadoEn DateTime @updatedAt
}

// Fase 3: historial de recorridos grabados (sección 5 y 11 del PDF).
// "puntos" guarda el arreglo [{lat, lon, timestamp}] como JSON en texto (SQLite no tiene tipo arreglo).
model Recorrido {
  id          Int      @id @default(autoincrement())
  miembroId   Int
  miembro     Miembro  @relation(fields: [miembroId], references: [id])
  tipo        String   @default("libre") // "ruta" | "libre"
  distanciaKm Float
  duracionSeg Int
  puntos      String
  favorito    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// Fase 4: feed de publicaciones oficiales de Comunidad (sección 6 del PDF).
// tipo: "comunicado" | "rodada" | "evento" | "resumen" | "alerta" | "estado_rutas" | "anuncio" | "consejo"
model Publicacion {
  id             Int      @id @default(autoincrement())
  tipo           String
  titulo         String
  texto          String
  fecha          String? // "YYYY-MM-DD", solo rodadas/eventos
  hora           String? // "HH:MM"
  puntoEncuentro String?
  rsvp           Boolean  @default(false)
  duracionHoras  Int? // vencimiento; null = no vence
  activaEnMapa   Boolean  @default(false)
  fotos          String? // JSON array de URLs (Fase 10: subida real vía /uploads)
  createdAt      DateTime @default(now())

  rsvps RsvpRespuesta[]
}

// Una respuesta de RSVP por miembro y publicación ("yes" | "maybe" | "no")
model RsvpRespuesta {
  id            Int         @id @default(autoincrement())
  publicacionId Int
  publicacion   Publicacion @relation(fields: [publicacionId], references: [id])
  miembroId     Int
  miembro       Miembro     @relation(fields: [miembroId], references: [id])
  estado        String // "yes" | "maybe" | "no"
  createdAt     DateTime    @default(now())
  actualizadoEn DateTime    @updatedAt

  @@unique([publicacionId, miembroId])
}

// Fase 5: feed social "Post" (sección 7 del PDF) — experiencias personales, distinto de Comunidad.
// Vigencia fija de 7 días (DIAS_VIGENCIA_POST), calculada en el backend igual que Publicacion.
// La subida real de fotos/video con editor de recorte queda para la Fase 10; por ahora "fotoUrl"
// es un link opcional a una imagen.
model Post {
  id        Int      @id @default(autoincrement())
  autorId   Int
  autor     Miembro  @relation(fields: [autorId], references: [id])
  titulo    String
  resena    String
  ubicacion String?
  fotoUrl   String?
  createdAt DateTime @default(now())

  reacciones  ReaccionPost[]
  comentarios ComentarioPost[]
}

model ReaccionPost {
  id        Int      @id @default(autoincrement())
  postId    Int
  post      Post     @relation(fields: [postId], references: [id])
  miembroId Int
  miembro   Miembro  @relation(fields: [miembroId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, miembroId])
}

model ComentarioPost {
  id        Int      @id @default(autoincrement())
  postId    Int
  post      Post     @relation(fields: [postId], references: [id])
  autorId   Int
  autor     Miembro  @relation(fields: [autorId], references: [id])
  texto     String
  createdAt DateTime @default(now())
}

// Fase 6: directorio de emprendedores "Impulsa" (sección 8 del PDF).
// Una ficha por miembro; requiere aprobación de un Admin antes de salir en el directorio público.
model Emprendedor {
  id            Int      @id @default(autoincrement())
  miembroId     Int      @unique
  miembro       Miembro  @relation(fields: [miembroId], references: [id])
  nombreNegocio String
  rubro         String
  descripcion   String
  contacto      String
  ubicacion     String?
  instagram     String?
  facebook      String?
  tiktok        String?
  fotos         String? // JSON array de URLs (Fase 10: subida real vía /uploads)
  aprobado      Boolean  @default(false)
  solicitadoAt  DateTime @default(now())

  reacciones ReaccionEmprendedor[]
  resenas    ResenaEmprendedor[]
  anuncios   AnuncioEmprendedor[]
}

model ReaccionEmprendedor {
  id            Int         @id @default(autoincrement())
  emprendedorId Int
  emprendedor   Emprendedor @relation(fields: [emprendedorId], references: [id])
  miembroId     Int
  miembro       Miembro     @relation(fields: [miembroId], references: [id])
  createdAt     DateTime    @default(now())

  @@unique([emprendedorId, miembroId])
}

model ResenaEmprendedor {
  id            Int         @id @default(autoincrement())
  emprendedorId Int
  emprendedor   Emprendedor @relation(fields: [emprendedorId], references: [id])
  autorId       Int
  autor         Miembro     @relation(fields: [autorId], references: [id])
  texto         String
  createdAt     DateTime    @default(now())
}

model AnuncioEmprendedor {
  id            Int         @id @default(autoincrement())
  emprendedorId Int
  emprendedor   Emprendedor @relation(fields: [emprendedorId], references: [id])
  texto         String
  createdAt     DateTime    @default(now())
}

// Fase 7: reconocimientos entre miembros (sección 9 del PDF). Vigencia de 15 días
// (DIAS_VIGENCIA_RECO), calculada en el backend comparando createdAt.
model ReconocimientoRecibido {
  id        Int      @id @default(autoincrement())
  deId      Int
  de        Miembro  @relation("reconocimientosEnviados", fields: [deId], references: [id])
  paraId    Int
  para      Miembro  @relation("reconocimientosRecibidos", fields: [paraId], references: [id])
  texto     String
  leida     Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Fase 8: chat grupal e individual (sección 9 y 11 del PDF).
// "sala" = "grupal" (chat único general) o "dm-{idMenor}-{idMayor}" para chats 1 a 1.
// Vigencia de 7 días (DIAS_VIGENCIA_CHAT), calculada en el backend comparando createdAt.
model MensajeChat {
  id             Int      @id @default(autoincrement())
  sala           String
  autorId        Int
  autor          Miembro  @relation(fields: [autorId], references: [id])
  texto          String
  referenciaTipo String? // "post" | "emprendedor"
  referenciaId   Int?
  createdAt      DateTime @default(now())

  @@index([sala])
}

// Marca hasta qué momento leyó cada miembro cada sala (para contar mensajes no leídos).
model LecturaChat {
  id         Int      @id @default(autoincrement())
  miembroId  Int
  miembro    Miembro  @relation(fields: [miembroId], references: [id])
  sala       String
  leidoHasta DateTime

  @@unique([miembroId, sala])
}

// Fase 9: SOS / Emergencia (sección 5 del PDF). Solo una emergencia activa por miembro a la vez;
// se conserva el historial (activa=false) en vez de borrar el registro.
model Emergencia {
  id                 Int       @id @default(autoincrement())
  miembroId          Int
  miembro            Miembro   @relation(fields: [miembroId], references: [id])
  motivo             String // "caida" | "salud" | "seguridad" | "otro"
  requiereAmbulancia Boolean   @default(false)
  activa             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  resueltaAt         DateTime?
}

// Historias efímeras estilo Instagram (vigencia HORAS_VIGENCIA_HISTORIA = 24h), en la
// barra sobre el feed de Post. Se calcula igual que Post (createdAt + filtro en el
// where, sin cron) — los registros vencidos no se borran, solo dejan de listarse.
model Historia {
  id        Int      @id @default(autoincrement())
  autorId   Int
  autor     Miembro  @relation("HistoriaAutor", fields: [autorId], references: [id])
  tipo      String // "foto" | "video"
  mediaUrl  String
  texto     String? // texto superpuesto opcional (contenido plano)
  // Posición/tamaño/rotación/tipografía/color/alineación/fondo del texto sobre
  // la imagen, como JSON en texto (mismo patrón que "puntos" en Recorrido) —
  // opaco para el backend, solo el frontend lo arma/interpreta.
  textoEstilo String?
  ubicacion String? // nombre de sector (sectorMasCercano), opcional
  createdAt DateTime @default(now())

  vistas      VistaHistoria[]
  reacciones  ReaccionHistoria[]
  menciones   MencionHistoria[]
  comentarios ComentarioHistoria[]

  @@index([autorId])
}

// Mención de otro integrante sobre la imagen (pegatina "@nombre", estilo
// Instagram) — hasta MAX_MENCIONES_POR_HISTORIA (5) por historia, cada una
// con su propia posición y escala arrastrable/pellizcable (igual dinámica que
// el texto, pero sin rotación). x/y son fracciones 0..1 del contenedor.
// aceptada: null = el mencionado todavía no respondió; true = aceptó que
// también aparezca bajo su propio avatar en la barra (sigue viéndose igual
// bajo el autor original); false = rechazó. Sin sistema de seguidores: el
// efecto de aceptar es solo que la MISMA historia se agrupa también bajo el
// mencionado, no una copia.
model MencionHistoria {
  id         Int      @id @default(autoincrement())
  historiaId Int
  historia   Historia @relation(fields: [historiaId], references: [id])
  miembroId  Int
  miembro    Miembro  @relation(fields: [miembroId], references: [id])
  x          Float
  y          Float
  escala     Float    @default(1)
  aceptada   Boolean?
  createdAt  DateTime @default(now())

  @@unique([historiaId, miembroId])
}

// Reacción rápida a una historia (el "patín dorado" de Legión Roller, en vez
// del corazón de Instagram) — un solo tipo de reacción, igual patrón que
// ReaccionPost. `leida` es la notificación liviana para el autor: se marca
// en `true` cuando el autor consulta la lista de quién reaccionó.
model ReaccionHistoria {
  id         Int      @id @default(autoincrement())
  historiaId Int
  historia   Historia @relation(fields: [historiaId], references: [id])
  miembroId  Int
  miembro    Miembro  @relation(fields: [miembroId], references: [id])
  leida      Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([historiaId, miembroId])
}

// Mensaje enviado a una historia mientras se está viendo. Se retransmite en
// vivo por WebSocket (burbuja flotante, ver HistoriasGateway) Y se guarda acá
// para que cualquiera pueda revisarlo más tarde (visible a todos, igual que
// ComentarioPost — no es un inbox privado del autor). Puede responder a otro
// comentario existente (`respuestaAId`), formando un hilo de un solo nivel.
model ComentarioHistoria {
  id           Int                  @id @default(autoincrement())
  historiaId   Int
  historia     Historia             @relation(fields: [historiaId], references: [id])
  autorId      Int
  autor        Miembro              @relation(fields: [autorId], references: [id])
  texto        String
  respuestaAId Int?
  respuestaA   ComentarioHistoria?  @relation("RespuestasComentarioHistoria", fields: [respuestaAId], references: [id])
  respuestas   ComentarioHistoria[] @relation("RespuestasComentarioHistoria")
  createdAt    DateTime             @default(now())

  @@index([historiaId])
}

// Qué historias ya vio cada miembro. Es por historia individual (no "leído hasta una
// fecha" como LecturaChat) porque el anillo dorado solo se apaga cuando TODAS las
// historias activas de ese autor fueron vistas, no basta una sola marca de tiempo.
model VistaHistoria {
  id         Int      @id @default(autoincrement())
  historiaId Int
  historia   Historia @relation(fields: [historiaId], references: [id])
  miembroId  Int
  miembro    Miembro  @relation(fields: [miembroId], references: [id])
  vistaAt    DateTime @default(now())

  @@unique([historiaId, miembroId])
}
