// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

// Fase 2: modelo mínimo para autenticación real.
// Los campos de la especificación (stats, tecnicas, reconocimientos, etc.)
// se agregan en las fases correspondientes (Perfil, Impulsa, etc.).
model Miembro {
  id           Int      @id @default(autoincrement())
  nombre       String
  // Ajuste post-registro-v2: el login pasa a ser por correo, no por teléfono
  // — telefono queda opcional (dato de contacto, ya no identificador de cuenta).
  telefono     String?  @unique
  correo       String   @unique
  fechaNacimiento DateTime?
  passwordHash String
  ciudad       String?
  rol          String   @default("usuario") // "usuario" | "admin"
  createdAt    DateTime @default(now())

  // Categorización interna que solo el admin ve/maneja (se asigna al aprobar
  // la solicitud, editable después desde "Todos los integrantes"): "legion" |
  // "comunidad" — pensada para más adelante dar accesos limitados dentro de
  // la app según la categoría (todavía no implementado, solo el dato).
  categoria String?

  // Fase 7: estado tipo "story" visible en el mapa (vigencia HORAS_ESTADO = 8h)
  estadoTexto String?
  estadoSetAt DateTime?

  // Ajuste post-Fase 11: foto de perfil circular, mostrada en el mapa mientras comparte ubicación
  fotoUrl String?

  // Ajuste post-Fase 12: mejor distancia alcanzada en una sola ruta/sesión
  // (no acumulada), para los hitos de "Distancias Alcanzadas" — se guarda
  // aparte de Recorrido para que un logro ya obtenido no se pierda si el
  // usuario borra esa ruta después (hay un tope de 10 rutas guardadas).
  mejorDistanciaRuta Float @default(0)

  // Ajuste post-Fase 12: técnicas dominadas por categorías (Frenos/Saltos/Fakie),
  // reemplaza las columnas booleanas fijas de la Fase 7 — no escalaban a una
  // lista más larga y extensible (ver CATALOGO_TECNICAS en el frontend).
  tecnicas MiembroTecnica[]

  // Ajuste post-Fase 12: galería de fotos del perfil (hasta 6, MAX_FOTOS_GALERIA),
  // cada una con su propio contador de "me gusta" — mismo patrón que Post/ReaccionPost.
  fotosGaleria           FotoGaleria[]
  reaccionesFotoGaleria  ReaccionFotoGaleria[]

  ubicacionActiva          UbicacionActiva?
  recorridos               Recorrido[]
  asistenciasRodada        AsistenciaRodada[]
  rsvps                    RsvpRespuesta[]
  posts                    Post[]
  reaccionesPost           ReaccionPost[]
  comentariosPost          ComentarioPost[]
  reaccionesComentarioPost ReaccionComentarioPost[]
  emprendedor              Emprendedor?
  reaccionesEmprendedor    ReaccionEmprendedor[]
  resenasEmprendedor       ResenaEmprendedor[]
  reaccionesResenaEmprendedor ReaccionResenaEmprendedor[]
  reconocimientosEnviados  ReconocimientoRecibido[] @relation("reconocimientosEnviados")
  reconocimientosRecibidos ReconocimientoRecibido[] @relation("reconocimientosRecibidos")
  mensajesChat             MensajeChat[]
  lecturasChat             LecturaChat[]
  emergencias              Emergencia[]
  historias                Historia[]                @relation("HistoriaAutor")
  vistasHistoria           VistaHistoria[]
  reaccionesHistoria       ReaccionHistoria[]
  mencionesHistoria        MencionHistoria[]
  comentariosHistoria      ComentarioHistoria[]
  ecosHistoria             EcoHistoria[]

  // Ajuste post-Fase 12: notificaciones push reales (Web Push), una fila por
  // dispositivo/navegador suscrito.
  suscripcionesPush SuscripcionPush[]

  // Ajuste: asistencias confirmadas a eventos (charlas/capacitaciones/actividades).
  asistenciasEvento AsistenciaEvento[]

  // Ajuste: rediseño de Chat — última vez que se desconectó su último socket
  // (no se guarda un booleano "en línea": se deriva en caliente desde
  // ChatPresenceService, igual que patinandoAhora() hace con actualizadoEn).
  ultimaConexion DateTime?

  reaccionesMensajeChat ReaccionMensajeChat[]
  mensajesOcultos       MensajeChatOculto[]
}

// Ajuste post-Fase 12: suscripción de Web Push de un dispositivo/navegador
// (ver notificaciones-push/). Un miembro puede tener varias (celular + laptop).
model SuscripcionPush {
  id        Int      @id @default(autoincrement())
  miembroId Int
  miembro   Miembro  @relation(fields: [miembroId], references: [id])
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

// Solicitud de registro pendiente de aprobación de un Admin (sección 3 y 13 del PDF)
model SolicitudRegistro {
  id           Int      @id @default(autoincrement())
  nombre       String
  telefono     String?  @unique
  correo       String?  @unique
  fechaNacimiento DateTime?
  fotoUrl      String?
  ciudad       String?
  passwordHash String
  estado       String   @default("pendiente") // "pendiente" | "aceptada" | "rechazada"
  createdAt    DateTime @default(now())
}

// Fase 3: "Estoy patinando ahora" — una ubicación activa por miembro (sección 5 del PDF).
// La vigencia (HORAS_VIGENCIA_PATINANDO = 4h) se calcula en el backend comparando actualizadoEn,
// no se guarda una fecha de expiración aparte.
model UbicacionActiva {
  id            Int      @id @default(autoincrement())
  miembroId     Int      @unique
  miembro       Miembro  @relation(fields: [miembroId], references: [id])
  lat           Float
  lon           Float
  // Ajuste post-Fase 11: "patinando" (solo comparte ubicación) o "ruta" (además graba
  // el recorrido); usado para filtrar el panel de "Patinadores activos".
  modo          String   @default("patinando")
  // Se fija solo al crear (no cambia con cada actualización de posición), para poder
  // mostrar "hace X min" desde que activó el modo, a diferencia de actualizadoEn.
  iniciadoEn    DateTime @default(now())
  actualizadoEn DateTime @updatedAt
}

// Fase 3: historial de recorridos grabados (sección 5 y 11 del PDF).
// "puntos" guarda el arreglo [{lat, lon, timestamp}] como JSON en texto (SQLite no tiene tipo arreglo).
model Recorrido {
  id          Int      @id @default(autoincrement())
  miembroId   Int
  miembro     Miembro  @relation(fields: [miembroId], references: [id])
  tipo        String   @default("libre") // "ruta" | "libre"
  distanciaKm Float
  duracionSeg Int
  puntos      String
  favorito    Boolean  @default(false)
  createdAt   DateTime @default(now())

  asistencia AsistenciaRodada?
}

// Ajuste post-Fase 12: asistencia confirmada a una rodada (reglas de validación
// en mapa.service.ts guardarRecorrido). Reemplaza el conteo ingenuo de RSVP
// "yes" en perfil.service.ts — ahora "asistencias" cuenta solo estas filas,
// creadas automáticamente cuando el recorrido cumple las 4 reglas (RSVP previo,
// modo "Estoy en Ruta" activado, cercanía GPS al punto de inicio dentro de la
// ventana horaria, y distancia mínima recorrida).
model AsistenciaRodada {
  id            Int         @id @default(autoincrement())
  publicacionId Int
  publicacion   Publicacion @relation(fields: [publicacionId], references: [id])
  miembroId     Int
  miembro       Miembro     @relation(fields: [miembroId], references: [id])
  recorridoId   Int         @unique
  recorrido     Recorrido   @relation(fields: [recorridoId], references: [id])
  createdAt     DateTime    @default(now())

  @@unique([publicacionId, miembroId])
}

// Fase 4: feed de publicaciones oficiales de Comunidad (sección 6 del PDF).
// tipo: "comunicado" | "rodada" | "evento" | "resumen" | "alerta" | "estado_rutas" | "anuncio" | "consejo"
model Publicacion {
  id             Int      @id @default(autoincrement())
  tipo           String
  titulo         String
  texto          String
  fecha          String? // "YYYY-MM-DD", solo rodadas/eventos
  hora           String? // "HH:MM"
  puntoEncuentro String?
  // Ajuste post-Fase 12: coordenadas reales del punto de inicio de una rodada
  // (fijadas por el Admin con un selector de mapa), necesarias para validar
  // la cercanía GPS al conceder asistencia confirmada (ver AsistenciaRodada).
  // puntoEncuentro sigue siendo el nombre visible; esto es solo para el cálculo.
  puntoLat       Float?
  puntoLon       Float?
  // Ajuste post-Fase 12: cómo se valida que un usuario "completó" la rodada
  // para conceder asistencia (ver AsistenciaRodada / mapa.service.ts). Sin
  // definir (rodadas creadas antes de este ajuste) cae en el comportamiento
  // histórico: distancia mínima fija (DISTANCIA_MINIMA_ASISTENCIA_KM).
  // "punto_llegada" | "distancia_minima" | "ida_vuelta" | "cierre_manual"
  tipoFinalizacion  String?
  puntoFinLat       Float? // solo si tipoFinalizacion = "punto_llegada"
  puntoFinLon       Float?
  distanciaMinimaKm Float? // solo si tipoFinalizacion = "distancia_minima"
  // solo si tipoFinalizacion = "cierre_manual": mientras sea false, cualquier
  // recorrido que cumpla el resto de las reglas obtiene asistencia; una vez
  // que el Admin la marca true (botón "Marcar rodada como finalizada"), deja
  // de concederse, sin importar la ventana horaria automática.
  cerrada           Boolean  @default(false)
  rsvp           Boolean  @default(false)
  duracionHoras  Int? // vencimiento; null = no vence
  activaEnMapa   Boolean  @default(false)
  fotos          String? // JSON array de URLs (Fase 10: subida real vía /uploads)
  createdAt      DateTime @default(now())

  // Ajuste post-Fase 12: recordatorio push 30 minutos antes de fecha+hora
  // (solo rodada/evento/anuncio, ver RecordatoriosScheduler). Evita reenviar
  // el aviso en cada tick del cron una vez que ya se envió una vez.
  recordatorioEnviado Boolean @default(false)

  // Ajuste: cómo se valida la asistencia a un EVENTO (charla/capacitación/
  // actividad, no ruta). Independiente de tipoFinalizacion (que es para
  // rodadas). "gps_puntual" reutiliza puntoLat/puntoLon de arriba.
  // "gps_puntual" | "codigo" | "cierre_manual" | "autoconfirmacion"
  tipoAsistenciaEvento String?
  codigoAsistencia     String? // solo si tipoAsistenciaEvento = "codigo"

  rsvps            RsvpRespuesta[]
  asistencias      AsistenciaRodada[]
  asistenciasEvento AsistenciaEvento[]
}

// Ajuste: asistencia confirmada a un EVENTO (ver reglas en
// publicaciones.service.ts confirmarAsistenciaEvento). Reemplaza el conteo
// ingenuo de RSVP "yes" en perfil.service.ts para la estadística "eventos",
// mismo criterio que AsistenciaRodada ya aplica a "asistencias".
model AsistenciaEvento {
  id            Int         @id @default(autoincrement())
  publicacionId Int
  publicacion   Publicacion @relation(fields: [publicacionId], references: [id])
  miembroId     Int
  miembro       Miembro     @relation(fields: [miembroId], references: [id])
  createdAt     DateTime    @default(now())

  @@unique([publicacionId, miembroId])
}

// Una respuesta de RSVP por miembro y publicación ("yes" | "maybe" | "no")
model RsvpRespuesta {
  id            Int         @id @default(autoincrement())
  publicacionId Int
  publicacion   Publicacion @relation(fields: [publicacionId], references: [id])
  miembroId     Int
  miembro       Miembro     @relation(fields: [miembroId], references: [id])
  estado        String // "yes" | "maybe" | "no"
  createdAt     DateTime    @default(now())
  actualizadoEn DateTime    @updatedAt

  @@unique([publicacionId, miembroId])
}

// Fase 5: feed social "Post" (sección 7 del PDF) — experiencias personales, distinto de Comunidad.
// Vigencia fija de 7 días (DIAS_VIGENCIA_POST), calculada en el backend igual que Publicacion.
// Hasta 3 fotos (carrusel) O 1 video, nunca ambos — igual criterio que Historia.tipo.
// `fotos` es un JSON array de URLs, mismo patrón que Publicacion.fotos.
model Post {
  id        Int      @id @default(autoincrement())
  autorId   Int
  autor     Miembro  @relation(fields: [autorId], references: [id])
  titulo    String
  resena    String
  ubicacion String?
  tipo      String   @default("foto") // "foto" | "video"
  fotos     String?  // JSON array de hasta 3 URLs (cuando tipo = "foto")
  videoUrl  String?  // cuando tipo = "video"
  createdAt DateTime @default(now())

  reacciones  ReaccionPost[]
  comentarios ComentarioPost[]
}

model ReaccionPost {
  id        Int      @id @default(autoincrement())
  postId    Int
  post      Post     @relation(fields: [postId], references: [id])
  miembroId Int
  miembro   Miembro  @relation(fields: [miembroId], references: [id])
  // Para la notificación de la campana: "me gusta" agrupados sin ver todavía
  // (mismo patrón que ReaccionHistoria.leida).
  leida     Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([postId, miembroId])
}

// Visible para cualquiera (no es un inbox privado del autor), con hilo de un
// solo nivel vía `respuestaAId` — mismo patrón que ComentarioHistoria.
model ComentarioPost {
  id           Int              @id @default(autoincrement())
  postId       Int
  post         Post             @relation(fields: [postId], references: [id])
  autorId      Int
  autor        Miembro          @relation(fields: [autorId], references: [id])
  texto        String
  respuestaAId Int?
  respuestaA   ComentarioPost?  @relation("RespuestasComentarioPost", fields: [respuestaAId], references: [id])
  respuestas   ComentarioPost[] @relation("RespuestasComentarioPost")
  // Para la notificación de la campana: en una respuesta, aplica al autor del
  // comentario respondido; en un comentario raíz, al autor del post.
  leida        Boolean          @default(false)
  createdAt    DateTime         @default(now())

  reacciones ReaccionComentarioPost[]

  @@index([postId])
}

// Corazón sobre un comentario puntual (no sobre el post) — interacción visual
// simple, sin generar notificación de campana (decisión explícita).
model ReaccionComentarioPost {
  id           Int            @id @default(autoincrement())
  comentarioId Int
  comentario   ComentarioPost @relation(fields: [comentarioId], references: [id])
  miembroId    Int
  miembro      Miembro        @relation(fields: [miembroId], references: [id])
  createdAt    DateTime       @default(now())

  @@unique([comentarioId, miembroId])
}

// Fase 6: directorio de emprendedores "Impulsa" (sección 8 del PDF).
// Una ficha por miembro; requiere aprobación de un Admin antes de salir en el directorio público.
model Emprendedor {
  id            Int      @id @default(autoincrement())
  miembroId     Int      @unique
  miembro       Miembro  @relation(fields: [miembroId], references: [id])
  nombreNegocio String
  rubro         String
  descripcion   String
  contacto      String?
  ubicacion     String?
  instagram     String?
  facebook      String?
  tiktok        String?
  fotos         String? // JSON array de URLs (Fase 10: subida real vía /uploads)
  aprobado      Boolean  @default(false)
  solicitadoAt  DateTime @default(now())

  reacciones ReaccionEmprendedor[]
  resenas    ResenaEmprendedor[]
  anuncios   AnuncioEmprendedor[]
}

model ReaccionEmprendedor {
  id            Int         @id @default(autoincrement())
  emprendedorId Int
  emprendedor   Emprendedor @relation(fields: [emprendedorId], references: [id])
  miembroId     Int
  miembro       Miembro     @relation(fields: [miembroId], references: [id])
  createdAt     DateTime    @default(now())

  @@unique([emprendedorId, miembroId])
}

// Visible para cualquiera (no es un inbox privado del dueño), con hilo de un
// solo nivel vía `respuestaAId` — mismo patrón que ComentarioPost.
model ResenaEmprendedor {
  id            Int                 @id @default(autoincrement())
  emprendedorId Int
  emprendedor   Emprendedor         @relation(fields: [emprendedorId], references: [id])
  autorId       Int
  autor         Miembro             @relation(fields: [autorId], references: [id])
  texto         String
  respuestaAId  Int?
  respuestaA    ResenaEmprendedor?  @relation("RespuestasResenaEmprendedor", fields: [respuestaAId], references: [id])
  respuestas    ResenaEmprendedor[] @relation("RespuestasResenaEmprendedor")
  // Para la notificación de la campana: en una respuesta, aplica al autor de
  // la reseña respondida; en una reseña raíz, al dueño de la ficha.
  leida         Boolean             @default(false)
  createdAt     DateTime            @default(now())

  reacciones ReaccionResenaEmprendedor[]

  @@index([emprendedorId])
}

// Corazón sobre una reseña puntual (no sobre la ficha) — interacción visual
// simple, sin generar notificación de campana (mismo criterio que
// ReaccionComentarioPost).
model ReaccionResenaEmprendedor {
  id        Int               @id @default(autoincrement())
  resenaId  Int
  resena    ResenaEmprendedor @relation(fields: [resenaId], references: [id])
  miembroId Int
  miembro   Miembro           @relation(fields: [miembroId], references: [id])
  createdAt DateTime          @default(now())

  @@unique([resenaId, miembroId])
}

model AnuncioEmprendedor {
  id            Int         @id @default(autoincrement())
  emprendedorId Int
  emprendedor   Emprendedor @relation(fields: [emprendedorId], references: [id])
  texto         String
  createdAt     DateTime    @default(now())
}

// Fase 7: reconocimientos entre miembros (sección 9 del PDF). Vigencia de 15 días
// (DIAS_VIGENCIA_RECO), calculada en el backend comparando createdAt.
model ReconocimientoRecibido {
  id        Int      @id @default(autoincrement())
  deId      Int
  de        Miembro  @relation("reconocimientosEnviados", fields: [deId], references: [id])
  paraId    Int
  para      Miembro  @relation("reconocimientosRecibidos", fields: [paraId], references: [id])
  texto     String
  leida     Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Fase 8: chat grupal e individual (sección 9 y 11 del PDF).
// "sala" = "grupal" (chat único general) o "dm-{idMenor}-{idMayor}" para chats 1 a 1.
// Vigencia de 7 días (DIAS_VIGENCIA_CHAT), calculada en el backend comparando createdAt.
model MensajeChat {
  id             Int      @id @default(autoincrement())
  sala           String
  autorId        Int
  autor          Miembro  @relation(fields: [autorId], references: [id])
  texto          String
  referenciaTipo String? // "post" | "emprendedor"
  referenciaId   Int?
  createdAt      DateTime @default(now())

  // Ajuste: rediseño de Chat — responder (hilo de un solo nivel, validado en
  // código igual que ComentarioPost: no se puede responder a una respuesta).
  respuestaAId Int?
  respuestaA   MensajeChat?  @relation("RespuestasMensajeChat", fields: [respuestaAId], references: [id])
  respuestas   MensajeChat[] @relation("RespuestasMensajeChat")

  // Ajuste: reenviar — apunta al mensaje original solo para mostrar la
  // etiqueta "Reenviado" (el texto/adjunto ya se copia a la fila nueva).
  reenviadoDeId Int?
  reenviadoDe   MensajeChat?  @relation("ReenviosMensajeChat", fields: [reenviadoDeId], references: [id])
  reenvios      MensajeChat[] @relation("ReenviosMensajeChat")

  // Ajuste: adjuntos. "ruta" guarda una foto (snapshot) de la Recorrido
  // elegida en vez de una FK, para que borrar la ruta original desde "Mis
  // rutas" no rompa un mensaje ya enviado.
  adjuntoTipo            String? // "foto" | "ubicacion" | "ruta"
  adjuntoUrl             String? // "foto"
  adjuntoUbicacionNombre String? // "ubicacion" — etiqueta descriptiva (sector más cercano)
  // Ajuste: ubicación exacta en Chat (a diferencia de Post/Historias, que solo
  // comparten el nombre del sector) — el chat es una conversación privada, no
  // un feed comunitario, así que acá sí tiene sentido compartir la posición
  // real, como hace WhatsApp.
  adjuntoUbicacionLat    Float?
  adjuntoUbicacionLon    Float?
  adjuntoRutaDistanciaKm Float?
  adjuntoRutaDuracionSeg Int?
  adjuntoRutaPuntos      String? // "ruta" — JSON [{lat,lon,timestamp}], decimado

  reacciones    ReaccionMensajeChat[]
  ocultamientos MensajeChatOculto[]

  @@index([sala])
}

// Marca hasta qué momento leyó (y, ahora, hasta qué momento recibió/entregó)
// cada miembro cada sala (para contar mensajes no leídos y los checks de
// enviado/entregado/leído, que solo tienen sentido en salas dm-* de 1 solo interlocutor).
model LecturaChat {
  id             Int       @id @default(autoincrement())
  miembroId      Int
  miembro        Miembro   @relation(fields: [miembroId], references: [id])
  sala           String
  leidoHasta     DateTime
  entregadoHasta DateTime?

  @@unique([miembroId, sala])
}

// Ajuste: reacción con emoji a un mensaje — una por persona por mensaje
// (re-reaccionar reemplaza, no apila). Sin campo "leida": no se pidió
// notificación de campana para esto, igual que ReaccionFotoGaleria.
model ReaccionMensajeChat {
  id        Int         @id @default(autoincrement())
  mensajeId Int
  mensaje   MensajeChat @relation(fields: [mensajeId], references: [id])
  miembroId Int
  miembro   Miembro     @relation(fields: [miembroId], references: [id])
  emoji     String
  createdAt DateTime    @default(now())

  @@unique([mensajeId, miembroId])
}

// Ajuste: "eliminar solo para mí" — oculta el mensaje únicamente para quien
// lo elimina, sin borrarlo para el resto (distinto de un borrado real, que
// usa DELETE directo sobre MensajeChat).
model MensajeChatOculto {
  id        Int         @id @default(autoincrement())
  mensajeId Int
  mensaje   MensajeChat @relation(fields: [mensajeId], references: [id])
  miembroId Int
  miembro   Miembro     @relation(fields: [miembroId], references: [id])
  createdAt DateTime    @default(now())

  @@unique([mensajeId, miembroId])
}

// Fase 9: SOS / Emergencia (sección 5 del PDF). Solo una emergencia activa por miembro a la vez;
// se conserva el historial (activa=false) en vez de borrar el registro.
model Emergencia {
  id                 Int       @id @default(autoincrement())
  miembroId          Int
  miembro            Miembro   @relation(fields: [miembroId], references: [id])
  motivo             String // "caida" | "salud" | "seguridad" | "otro"
  requiereAmbulancia Boolean   @default(false)
  activa             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  resueltaAt         DateTime?
}

// Historias efímeras estilo Instagram (vigencia HORAS_VIGENCIA_HISTORIA = 24h), en la
// barra sobre el feed de Post. Se calcula igual que Post (createdAt + filtro en el
// where, sin cron) — los registros vencidos no se borran, solo dejan de listarse.
model Historia {
  id        Int      @id @default(autoincrement())
  autorId   Int
  autor     Miembro  @relation("HistoriaAutor", fields: [autorId], references: [id])
  tipo      String // "foto" | "video"
  mediaUrl  String
  texto     String? // texto superpuesto opcional (contenido plano)
  // Posición/tamaño/rotación/tipografía/color/alineación/fondo del texto sobre
  // la imagen, como JSON en texto (mismo patrón que "puntos" en Recorrido) —
  // opaco para el backend, solo el frontend lo arma/interpreta.
  textoEstilo String?
  ubicacion String? // nombre de sector (sectorMasCercano), opcional
  createdAt DateTime @default(now())

  vistas      VistaHistoria[]
  reacciones  ReaccionHistoria[]
  menciones   MencionHistoria[]
  comentarios ComentarioHistoria[]
  ecos        EcoHistoria[]

  @@index([autorId])
}

// Mención de otro integrante sobre la imagen (pegatina "@nombre", estilo
// Instagram) — hasta MAX_MENCIONES_POR_HISTORIA (5) por historia, cada una
// con su propia posición y escala arrastrable/pellizcable (igual dinámica que
// el texto, pero sin rotación). x/y son fracciones 0..1 del contenedor.
// aceptada: null = el mencionado todavía no respondió; true = aceptó que
// también aparezca bajo su propio avatar en la barra (sigue viéndose igual
// bajo el autor original); false = rechazó. Sin sistema de seguidores: el
// efecto de aceptar es solo que la MISMA historia se agrupa también bajo el
// mencionado, no una copia.
model MencionHistoria {
  id         Int      @id @default(autoincrement())
  historiaId Int
  historia   Historia @relation(fields: [historiaId], references: [id])
  miembroId  Int
  miembro    Miembro  @relation(fields: [miembroId], references: [id])
  x          Float
  y          Float
  escala     Float    @default(1)
  aceptada   Boolean?
  createdAt  DateTime @default(now())

  @@unique([historiaId, miembroId])
}

// Reacción rápida a una historia (el "patín dorado" de Legión Roller, en vez
// del corazón de Instagram) — un solo tipo de reacción, igual patrón que
// ReaccionPost. `leida` es la notificación liviana para el autor: se marca
// en `true` cuando el autor consulta la lista de quién reaccionó.
model ReaccionHistoria {
  id         Int      @id @default(autoincrement())
  historiaId Int
  historia   Historia @relation(fields: [historiaId], references: [id])
  miembroId  Int
  miembro    Miembro  @relation(fields: [miembroId], references: [id])
  leida      Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([historiaId, miembroId])
}

// Mensaje enviado a una historia mientras se está viendo. Se retransmite en
// vivo por WebSocket (burbuja flotante, ver HistoriasGateway) Y se guarda acá
// para que cualquiera pueda revisarlo más tarde (visible a todos, igual que
// ComentarioPost — no es un inbox privado del autor). Puede responder a otro
// comentario existente (`respuestaAId`), formando un hilo de un solo nivel.
model ComentarioHistoria {
  id           Int                  @id @default(autoincrement())
  historiaId   Int
  historia     Historia             @relation(fields: [historiaId], references: [id])
  autorId      Int
  autor        Miembro              @relation(fields: [autorId], references: [id])
  texto        String
  respuestaAId Int?
  respuestaA   ComentarioHistoria?  @relation("RespuestasComentarioHistoria", fields: [respuestaAId], references: [id])
  respuestas   ComentarioHistoria[] @relation("RespuestasComentarioHistoria")
  // Para la notificación de la campana: marca si ya se vio este comentario.
  // En una respuesta (respuestaAId no nulo), aplica al autor del comentario
  // respondido; en un comentario raíz, aplica al autor de la historia.
  // Empieza en false.
  leida        Boolean              @default(false)
  createdAt    DateTime             @default(now())

  @@index([historiaId])
}

// "Eco": a diferencia de un ComentarioHistoria (que solo aparece flotando un
// instante para quien esté viendo la historia justo en ese momento, y después
// solo vive en el hilo de "comentarios"), un Eco queda FIJO y visible sobre la
// imagen de la historia para cualquiera que la abra, en cualquier momento,
// mientras la historia siga activa — es un concepto aparte, sin hilo de
// respuestas ni reacciones propias, solo texto + autor + fecha.
model EcoHistoria {
  id         Int      @id @default(autoincrement())
  historiaId Int
  historia   Historia @relation(fields: [historiaId], references: [id])
  autorId    Int
  autor      Miembro  @relation(fields: [autorId], references: [id])
  texto      String
  createdAt  DateTime @default(now())

  @@index([historiaId])
}

// Qué historias ya vio cada miembro. Es por historia individual (no "leído hasta una
// fecha" como LecturaChat) porque el anillo dorado solo se apaga cuando TODAS las
// historias activas de ese autor fueron vistas, no basta una sola marca de tiempo.
model VistaHistoria {
  id         Int      @id @default(autoincrement())
  historiaId Int
  historia   Historia @relation(fields: [historiaId], references: [id])
  miembroId  Int
  miembro    Miembro  @relation(fields: [miembroId], references: [id])
  vistaAt    DateTime @default(now())

  @@unique([historiaId, miembroId])
}

// Ajuste post-Fase 12: técnicas dominadas organizadas por categorías (Frenos,
// Saltos, Patinaje en Fakie) — una fila por técnica activa (mismo criterio
// que una reacción), en vez de una columna booleana por técnica. `tecnica`
// es una clave estable definida en CATALOGO_TECNICAS (frontend); el backend
// solo valida contra la lista plana de claves válidas.
model MiembroTecnica {
  id        Int      @id @default(autoincrement())
  miembroId Int
  miembro   Miembro  @relation(fields: [miembroId], references: [id])
  tecnica   String
  createdAt DateTime @default(now())

  @@unique([miembroId, tecnica])
}

// Ajuste post-Fase 12: galería de fotos del perfil (hasta MAX_FOTOS_GALERIA = 6).
// Una fila por foto (no un JSON array como Emprendedor.fotos) porque cada foto
// necesita su propio id y su propio contador de "me gusta".
model FotoGaleria {
  id        Int      @id @default(autoincrement())
  miembroId Int
  miembro   Miembro  @relation(fields: [miembroId], references: [id])
  url       String
  createdAt DateTime @default(now())

  reacciones ReaccionFotoGaleria[]

  @@index([miembroId])
}

// Corazón sobre una foto puntual de la galería — mismo patrón que ReaccionPost,
// sin campo `leida` ni notificación de campana (no se pidió, mismo criterio
// minimalista que ReaccionEmprendedor).
model ReaccionFotoGaleria {
  id        Int         @id @default(autoincrement())
  fotoId    Int
  foto      FotoGaleria @relation(fields: [fotoId], references: [id])
  miembroId Int
  miembro   Miembro     @relation(fields: [miembroId], references: [id])
  createdAt DateTime    @default(now())

  @@unique([fotoId, miembroId])
}
