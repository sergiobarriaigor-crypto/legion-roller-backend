# Copiar como .env y completar con valores reales (nunca commitear el .env real).

# Cadena de conexión a la base de datos. En local: SQLite ("file:./dev.db").
# En producción (Railway): la URL de Postgres que da el addon, ej.
# postgresql://usuario:password@host:5432/nombre_db
DATABASE_URL="file:./dev.db"

# Secreto para firmar los tokens de sesión (JWT). Generar uno propio y único en producción,
# por ejemplo con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="cambiar-por-un-secreto-largo-y-aleatorio"

# Notificaciones push (Web Push). Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@tu-dominio.com"
